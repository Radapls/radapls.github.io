---
import { LOCALES, useTranslations, type Lang } from 'src/i18n';
import Layout from '@layouts/Layout.astro';
import EmptyState from '@components/Blog/EmptyState.astro';

import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
const locale = Astro.currentLocale as Lang;

const posts = (await getCollection('blog'))
	.filter((post) => post.id.split('/')[0] === locale)
	.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

const title = 'Juan Felipe Rada | Blog';

export const getStaticPaths = () =>
	Object.keys(LOCALES).map((lang) => ({
		params: { lang },
	}));

const t = useTranslations(Astro.currentLocale as Lang);

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<Layout {title} noLinks>
	<section class="section container">
		<h2 class="section__title">
			{
				t({
					es: 'Algunas publicaciones del pasado',
					en: 'Some post of the past',
					'pt-br': 'Alguns postagens do passado',
				})
			}
		</h2>

		{allTags.length > 0 && (
			<div class="tag-filters" id="tag-filters">
				<button class="tag-btn active" data-tag="all">
					{t({ en: 'All', es: 'Todos', 'pt-br': 'Todos' })}
				</button>
				{allTags.map((tag) => (
					<button class="tag-btn" data-tag={tag}>{tag}</button>
				))}
			</div>
		)}

		{
			posts.length !== 0 ? (
				<ul class="blog-list" id="blog-list">
					{posts.map((post) => {
						const [, ...id] = post.id.split('/');
						return (
							<li data-tags={post.data.tags.join(',')}>
								<a href={`/${locale}/blog/${id.join('/')}/`}>
									{post.data.cover && <Image src={post.data.cover} alt={post.data.title} width={600} height={200} />}
									<h3>{post.data.title}</h3>
									{post.data.tags.length > 0 && (
										<div class="post-tags">
											{post.data.tags.map((tag) => <span class="post-tag">{tag}</span>)}
										</div>
									)}
								</a>
							</li>
						);
					})}
				</ul>
			) : (
				<EmptyState />
			)
		}
	</section>
</Layout>

<style>
	h2 {
		margin-bottom: 2rem;
	}

	.blog-list {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2rem;
	}

	@media screen and (max-width: 568px) {
		.blog-list {
			grid-template-columns: 1fr;
		}
	}

	img {
		border-radius: 0.5rem;
		object-fit: cover;
		aspect-ratio: auto;
		max-height: 200px;
	}

	.tag-filters {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 2rem;
	}

	.tag-btn {
		padding: 0.35rem 0.85rem;
		border: 1px solid var(--first-color);
		border-radius: 2rem;
		background: transparent;
		color: var(--first-color);
		font-family: 'Poppins';
		font-size: var(--small-font-size);
		cursor: pointer;
		transition: all 0.3s ease;
	}

	.tag-btn.active,
	.tag-btn:hover {
		background: var(--first-color);
		color: #fff;
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		margin-top: 0.5rem;
	}

	.post-tag {
		font-size: 0.75rem;
		padding: 0.15rem 0.5rem;
		border-radius: 1rem;
		background: var(--first-color-lighter);
		color: var(--first-color);
	}

	li[hidden] {
		display: none;
	}
</style>

<script is:inline>
	function setupTagFilter() {
		var filters = document.getElementById('tag-filters');
		if (!filters) return;

		filters.addEventListener('click', function(e) {
			var btn = e.target.closest('[data-tag]');
			if (!btn) return;

			filters.querySelector('.active').classList.remove('active');
			btn.classList.add('active');

			var tag = btn.dataset.tag;
			document.querySelectorAll('#blog-list li').forEach(function(li) {
				li.hidden = tag !== 'all' && !li.dataset.tags.split(',').includes(tag);
			});
		});
	}

	setupTagFilter();
	document.addEventListener('astro:after-swap', setupTagFilter);
</script>
