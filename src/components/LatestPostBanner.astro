---
import { getCollection } from 'astro:content';
import { useTranslations, type Lang } from 'src/i18n';

const lang = Astro.currentLocale as Lang;
const t = useTranslations(lang);

const posts = await getCollection('blog', ({ id }) => id.startsWith(`${lang}/`));
const latestPost = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];
---

{latestPost && (
  <div class="latest-post-banner" id="latest-post-banner" transition:animate="fade">
    <div class="banner-content">
      <span class="banner-label">
        {t({ en: '📝 Latest Post:', es: '📝 Última Publicación:', 'pt-br': '📝 Última Postagem:' })}
      </span>
      <a href={`/${lang}/blog/${latestPost.id.split('/').slice(1).join('/')}`} class="banner-link">
        {latestPost.data.title}
      </a>
      <button class="banner-close" id="banner-close" aria-label="Close banner">✕</button>
    </div>
  </div>
)}

<style>
  .latest-post-banner {
    width: 100%;
    background: linear-gradient(135deg, var(--first-color) 0%, var(--first-color-alt) 100%);
    padding: 0.65rem 2rem;
    text-align: center;
    position: fixed;
    top: 0;
    left: 0;
    z-index: calc(var(--z-fixed) + 1);
  }

  .latest-post-banner.hidden {
    display: none;
  }

  .banner-content {
    max-width: 1024px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .banner-label {
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .banner-link {
    color: #fff;
    text-decoration: underline;
    font-weight: 500;
    transition: opacity 0.3s ease;
  }

  .banner-link:hover {
    opacity: 0.8;
  }

  .banner-close {
    background: none;
    border: none;
    color: #fff;
    font-size: 1.25rem;
    cursor: pointer;
    padding: 0 0.5rem;
    line-height: 1;
    transition: opacity 0.3s ease;
  }

  .banner-close:hover {
    opacity: 0.7;
  }

  @media screen and (max-width: 768px) {
    .latest-post-banner {
      padding: 0.75rem 1rem;
    }

    .banner-label,
    .banner-link {
      font-size: 0.875rem;
    }
  }
</style>

<script is:inline>
  function setupBanner() {
    var banner = document.getElementById('latest-post-banner');
    var closeBtn = document.getElementById('banner-close');
    if (!banner || !closeBtn) return;

    var dismissed = localStorage.getItem('bannerDismissed') === 'true';

    if (dismissed) {
      banner.classList.add('hidden');
    }

    var h = dismissed ? 0 : banner.offsetHeight;
    document.documentElement.style.setProperty('--banner-height', h + 'px');

    closeBtn.addEventListener('click', function() {
      banner.classList.add('hidden');
      document.documentElement.style.setProperty('--banner-height', '0px');
      localStorage.setItem('bannerDismissed', 'true');
    });
  }

  setupBanner();
  document.addEventListener('astro:after-swap', setupBanner);
</script>
